# ── IWC Concepts — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values, then run npm run build

# ── Supabase Cloud Database (optional) ─────────────────────────────────────
# Create a free project at https://supabase.com → Settings → API
# Without these the app stores data locally in IndexedDB.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App Password (local mode only) ─────────────────────────────────────────
# Used when Supabase is NOT configured. Set any password you like.
# When Supabase IS configured, create users in Supabase → Authentication → Users.

